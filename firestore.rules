rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Per-user workspace: only the signed-in user may read/write their subtree.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // User Messages Queue
    match /users/{userId}/messages/{messageId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && (request.auth.uid == userId || resource.data.fromUid == request.auth.uid);
      allow create, update: if request.auth != null && request.resource.data.fromUid == request.auth.uid;
    }
    
    // Push Subscriptions (any authenticated user can read, only owner can write)
    match /users/{userId}/push_subscriptions/{subId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // User Directory (Public read, owner write)
    match /directory_by_email/{emailHash} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.data.uid == request.auth.uid;
    }
  }
}
